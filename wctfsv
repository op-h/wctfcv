def parse_headers(headers_list):
    headers = {}
    if headers_list:
        for h in headers_list:
            if ":" in h:
                key, value = h.split(":", 1)
                headers[key.strip()] = value.strip()
    return headers


def parse_cookies(cookie_list):
    cookies = {}
    if cookie_list:
        for c in cookie_list:
            if "=" in c:
                key, value = c.split("=", 1)
                cookies[key.strip()] = value.strip()
    return cookies


def parse_data(data_list):
    data = {}
    if data_list:
        for d in data_list:
            if "=" in d:
                key, value = d.split("=", 1)
                data[key.strip()] = value.strip()
    return data


def cmd_sqli(args):
    headers = parse_headers(args.header)
    cookies = parse_cookies(args.cookie)
    data = parse_data(args.data)
    method = "POST" if args.data else "GET"

    scanner = SQLiScanner(
        url=args.url,
        method=method,
        data=data,
        headers=headers,
        cookies=cookies,
        timeout=args.timeout,
    )
    results = scanner.scan()
    scanner.print_results(results)

    if results["vulnerable"] and args.dump:
        param = results["injectable_params"][0]
        tables = scanner.dump_tables(param)
        if tables:
            console.print(f"\n[bold]Tables found:[/bold]")
            for t in tables:
                console.print(f"  [cyan]->[/cyan] {t}")

            for table in tables[:3]:
                columns = scanner.dump_columns(param, table)
                if columns:
                    console.print(f"\n[bold]Columns in {table}:[/bold] {', '.join(columns)}")
                    data_rows = scanner.dump_data(param, table, columns[:3])
                    if data_rows:
                        console.print(f"[bold]Data:[/bold]")
                        for row in data_rows[:5]:
                            console.print(f"  {row}")

    if results["vulnerable"] and args.exploit:
        param = results["injectable_params"][0]
        payload = args.exploit
        resp = scanner._send(payload)
        console.print(f"\n[bold]Exploit result:[/bold]")
        console.print(f"Status: {resp.status_code}")
        console.print(f"Length: {len(resp.text)}")
        console.print(resp.text[:2000])


def cmd_xss(args):
    headers = parse_headers(args.header)
    cookies = parse_cookies(args.cookie)
    data = parse_data(args.data)
    method = "POST" if args.data else "GET"

    scanner = XSSScanner(
        url=args.url,
        param=args.param,
        method=method,
        data=data,
        headers=headers,
        cookies=cookies,
        timeout=args.timeout,
    )
    results = scanner.scan()
    scanner.print_results(results)

    if args.payloads:
        payloads = scanner.generate_payloads(args.filter)
        console.print(f"\n[bold]Generated payloads ({len(payloads)}):[/bold]")
        for i, payload in enumerate(payloads, 1):
            console.print(f"  {i}. {payload}")

    if results["vulnerable"] and args.exploit:
        param = results["reflected"][0] if results["reflected"] else args.param
        payload = args.exploit
        resp = scanner._send(payload)
        console.print(f"\n[bold]Exploit result:[/bold]")
        console.print(f"Status: {resp.status_code}")
        console.print(f"Length: {len(resp.text)}")


def cmd_brute(args):
    headers = parse_headers(args.header)
    cookies = parse_cookies(args.cookie)

    bruter = DirectoryBruter(
        url=args.url,
        wordlist=args.wordlist,
        extensions=args.extensions.split(",") if args.extensions else None,
        threads=args.threads,
        timeout=args.timeout,
        headers=headers,
        cookies=cookies,
    )

    if args.paths:
        paths = args.paths.split(",")
        results = bruter.scan_custom(paths)
    else:
        results = bruter.scan()

    if results:
        bruter.print_results(results)
    else:
        console.print("[yellow]No paths found[/yellow]")

    if args.json_output:
        with open(args.json_output, "w") as f:
            json.dump(results, f, indent=2)
        console.print(f"\n[green]Results saved to {args.json_output}[/green]")


