  %(prog)s -u "http://target.com" --manipulate "session=admin"
  %(prog)s -u "http://target.com" -H "Cookie: token=abc123" -j cookies.json
        """)
    cookies_parser.add_argument("--manipulate", help="Set cookie value for testing (e.g., --manipulate 'session=admin')")
    cookies_parser.add_argument("--payloads", action="store_true", help="Generate cookie manipulation payloads")
    cookies_parser.add_argument("--cookie-name", help="Cookie name for payload generation (e.g., --cookie-name session)")

    all_parser = subparsers.add_parser("all", parents=[common_args], help="Run all modules", formatter_class=argparse.RawDescriptionHelpFormatter, epilog="""
Run All Examples:
  %(prog)s -u "http://target.com"
  %(prog)s -u "http://target.com" --threads 20 -j results.json
  %(prog)s -u "http://target.com" -H "Cookie: auth=token" -d "user=admin" --threads 15
        """)
    all_parser.add_argument("-d", "--data", action="append", help="POST data, repeatable (e.g., -d 'user=admin')")
    all_parser.add_argument("--threads", type=int, default=10, help="Number of threads (default: 10)")

    args = parser.parse_args()

    if not args.command:
        console.print(BANNER)
        parser.print_help()
        sys.exit(0)

    console.print(BANNER)

    commands = {
        "sqli": cmd_sqli,
        "xss": cmd_xss,
        "brute": cmd_brute,
        "subdomains": cmd_subdomains,
        "headers": cmd_headers,
        "source": cmd_source,
        "cookies": cmd_cookies,
        "all": cmd_all,
    }

    try:
        commands[args.command](args)
    except KeyboardInterrupt:
        console.print("\n[yellow]Scan interrupted by user[/yellow]")
        sys.exit(1)
    except Exception as e:
        console.print(f"\n[red]Error: {e}[/red]")
        sys.exit(1)


if __name__ == "__main__":
    main()
